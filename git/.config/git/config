[core]
	editor = nvim
	pager = delta
[init]
	defaultBranch = main # remove once git defaults to `main`
[user]
	name = Daniel Schmid
	email = mail+git@ybc37.dev
[color]
	ui = true
[pull]
	ff = only
[push]
	default = simple
[merge]
	tool = meld
	conflictstyle = zdiff3
[rebase]
	autoSquash = true

	# https://andrewlock.net/working-with-stacked-branches-in-git-is-easier-with-update-refs/
    updateRefs = true
[diff]
	algorithm = histogram
	tool = meld
	colorMoved = default
[rerere]
	enabled = true
[interactive]
	diffFilter = delta --color-only
[gui]
	fontui = -family \"Noto Sans\" -size 10 -weight normal -slant roman -underline 0 -overstrike 0
	fontdiff = -family \"Iosevka\" -size 10 -weight normal -slant roman -underline 0 -overstrike 0
[alias]
	lg = log --color --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cI) %C(bold blue)<%an>%Creset'
	lgg = log --color --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cI) %C(bold blue)<%an>%Creset' --graph
	in = "lg ..@{u}"
	out = "lg @{u}.."
    jump = "!/usr/share/git/git-jump/git-jump"
[delta]
	navigate = true
	keep-plus-minus-markers = true
	file-style = omit
	hunk-header-decoration-style = brightblack ul ol
	hunk-header-line-number-style = brightmagenta
	hunk-header-file-style = brightblue
	hunk-header-style = file line-number syntax
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[includeIf "gitdir:~/dev/work/"]
    path = work.inc
